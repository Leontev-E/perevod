# ─── Perevod — environment ───────────────────────────────────────────────
# Copy to .env (the installer does this for you) and adjust.
# .env is read by docker compose at runtime and is NOT baked into the image.

# Password gate for the web UI (the installer generates a strong random one).
APP_PASSWORD=change-me

# Secret used to sign session cookies (the installer generates a random one).
SESSION_SECRET=change-me-too

# Host port the UI is exposed on (http://SERVER_IP:WEB_PORT).
WEB_PORT=8070

# Absolute public URL, used only to build download/preview links in the UI.
# Set this to your domain if you put the app behind a reverse proxy + HTTPS.
PUBLIC_BASE_URL=http://localhost:8070

# ─── kie.ai API key ──────────────────────────────────────────────────────
# The kie.ai key is NOT stored here. Open the running app → ⚙ Settings and
# paste it there once. It is saved to /data/settings.json (a persistent Docker
# volume) and survives rebuilds. Get a key at https://kie.ai → API Keys.
# (KIE_API_KEY below is only an optional fallback for headless/dev use.)
# KIE_API_KEY=

# ─── Optional overrides ──────────────────────────────────────────────────
# KIE_GPT_MODEL=gpt-5-5
# KIE_CLAUDE_MODEL=claude-sonnet-5
# KIE_IMAGE_MODEL=gpt-image-2-image-to-image
# MAX_IMAGES=60
# MAX_UPLOAD_MB=80
